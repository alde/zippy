#!/usr/bin/env bash
# Lightweight zig shim — resolves version from .zippy file or global default,
# then exec's the real zig binary. No shell startup cost.
set -euo pipefail

ZIPPY_DIR="${ZIPPY_HOME:-$HOME/.zippy}"

# walk up from cwd looking for .zippy
dir="$PWD"
while true; do
  if [[ -f "$dir/.zippy" ]]; then
    version="$(< "$dir/.zippy")"
    break
  fi
  [[ "$dir" != "/" ]] || break
  dir="${dir%/*}"
  [[ -n "$dir" ]] || dir="/"
done

# fall back to global default
if [[ -z "${version:-}" && -f "$ZIPPY_DIR/default" ]]; then
  version="$(< "$ZIPPY_DIR/default")"
fi

if [[ -z "${version:-}" ]]; then
  echo "zippy: no zig version set (use 'zippy use <version>' or create a .zippy file)" >&2
  exit 1
fi

zig="$ZIPPY_DIR/versions/$version/zig"
if [[ ! -x "$zig" ]]; then
  echo "zippy: zig $version is not installed (run: zippy install $version)" >&2
  exit 1
fi

exec "$zig" "$@"
